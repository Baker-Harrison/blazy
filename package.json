{
  "name": "blazy",
  "version": "0.1.0",
  "description": "Blazy",
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently -k -s first \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.blazy.app",
    "productName": "Blazy",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "assets/icon.*",
      "!**/*.sqlite",
      "!**/*.db"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/sql.js/dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Baker-Harrison",
      "repo": "blazy",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "electron-reloader": "^1.2.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "sql.js": "^1.14.1"
  }
}
